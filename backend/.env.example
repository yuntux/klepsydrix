# Configuration de l'application Klepsydrix Backend

# URL de connexion à la base de données
# SQLite local par défaut, peut être remplacé par PostgreSQL en production
DATABASE_URL=sqlite:///./timetable.db

# Limite de temps accordée au solveur en secondes (par exemple 300 secondes)
SOLVER_TIME_LIMIT_SECONDS=300

# Limite d'inactivité/stagnation en secondes (s'arrête si aucune amélioration du score)
SOLVER_UNIMPROVED_TIME_LIMIT_SECONDS=10
