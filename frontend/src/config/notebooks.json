                          "key": "first_name",
                          "overrideLabel": "Prénom",
                          "required": true,
                          "readOnly": false
                        }
                      ]
                    },
                    {
                      "type": "newline"
                    },
                    {
                      "type": "separator",
                      "string": "Paramètres Contractuels"
