                "resourceKey": "resource_constraints",
                "relationName": "constraint_record",
                "width": "30%",
                "placeholderText": "Veuillez choisir un enseignant dans la liste de gauche pour configurer ses contraintes.",
                "formConfig": {
                  "editableForm": true,
                  "fields": [
                    {
                      "type": "group",
                      "string": "Max Horaire [M]",
                      "col": 3,
                      "children": [
                        {
                          "key": "max_hours_per_day",
                          "overrideLabel": "Journée",
                          "readOnly": false,
                          "help": "Nombre maximum d'heures de cours qu'un enseignant peut effectuer par jour.\n- **Valeur type** : 6 à 8 heures.\n- **Impact** : Règle dure dans le solveur."
                        },
                        {
                          "key": "max_hours_per_am",
                          "overrideLabel": "Matin",
                          "readOnly": false,
                          "help": "Volume d'heures maximum autorisées en matinée (avant 12h).\n- **Impact** : Permet de préserver la fatigue matinale."
                        },
                        {
                          "key": "max_hours_per_pm",
                          "overrideLabel": "Après-midi",
                          "readOnly": false,
                          "help": "Volume d'heures maximum autorisées l'après-midi (à partir de 12h).\n- **Impact** : Permet d'éviter les surcharges de fin de journée."
                        }
                      ]
                    },
                    {
                      "type": "group",
                      "string": "Maximum Présentiel [P]",
                      "col": 2,
                      "children": [
                        {
                          "key": "max_presence_days_per_week",
                          "overrideLabel": "Jours max / sem.",
                          "readOnly": false
                        },
                        {
                          "key": "max_presence_hours_per_day",
                          "overrideLabel": "Journées d'au plus (h)",
                          "readOnly": false
                        }
                      ]
                    },
                    {
                      "type": "group",
                      "string": "Horaires Aménagés [A]",
                      "col": 2,
                      "children": [
                        {
                          "key": "late_start_days_per_week",
                          "overrideLabel": "Commencer",
                          "readOnly": false
                        },
                        {
                          "key": "late_start_time",
                          "overrideLabel": "jours/sem. au plus tôt à",
                          "readOnly": false
                        },
                        {
                          "key": "early_end_days_per_week",
                          "overrideLabel": "Terminer",
                          "readOnly": false
                        },
                        {
                          "key": "early_end_time",
                          "overrideLabel": "jours/sem. au plus tard à",
                          "readOnly": false
                        }
                      ]
                    },
                    {
                      "type": "group",
                      "string": "Plages Libres Garanties [G]",
                      "col": 2,
                      "children": [
                        {
                          "key": "min_free_days_per_week",
                          "overrideLabel": "Garantir (journées)",
                          "readOnly": false
                        },
                        {
                          "key": "min_free_half_days_per_week",
                          "overrideLabel": "Demi-journées libres",
                          "readOnly": false
                        }
                      ]
                    },
                    {
                      "type": "group",
                      "string": "Maximum de demi-journées de travail [J]",
                      "col": 2,
                      "children": [
                        {
                          "key": "max_worked_am_per_week",
                          "overrideLabel": "Matin",
                          "readOnly": false
                        },
                        {
                          "key": "max_worked_pm_per_week",
                          "overrideLabel": "Après-midi",
                          "readOnly": false
                        },
                        {
                          "key": "only_one_half_day_per_day",
                          "overrideLabel": "Ne travailler \n qu'1/2 j. par j.",
                          "readOnly": false,
                          "help": "Interdire strictement d'avoir des cours prévus à la fois le matin et l'après-midi sur un même jour.\n- **Impact** : Règle dure du solveur."
                        }
                      ]
                    },
                    {
                      "type": "group",
                      "string": "Préférences d'Optimisation",
                      "col": 2,
                      "children": [
                        {
                          "key": "max_gap_hours_per_week",
                          "overrideLabel": "Nombre d'heures de trous tolérées",
                          "readOnly": false
                        }
                      ]
                    }
