                    {
                      "type": "group",
                      "string": "Contrat & Rattachement",
                      "col": 2,
                      "children": [
                        {
                          "key": "max_weekly_hours",
                          "overrideLabel": "Heures de cours max par semaine",
                          "required": true,
                          "readOnly": false
                        },
                        {
                          "key": "school_id",
                          "overrideLabel": "Établissement principal",
                          "required": true,
                          "readOnly": false
                        }
                      ]
                    }
                  ]
                }
              }
            ]
