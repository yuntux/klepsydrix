                      "col": 2,
                      "children": [
                        {
                          "key": "code",
                          "overrideLabel": "Code",
                          "required": true,
                          "readOnly": false
                        },
                        {
                          "key": "last_name",
                          "overrideLabel": "Nom de famille",
                          "required": true,
                          "readOnly": false
                        },
